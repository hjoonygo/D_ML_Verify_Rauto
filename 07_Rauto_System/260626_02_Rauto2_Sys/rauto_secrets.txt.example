# Rauto2 시크릿 템플릿 — 이 파일을 'rauto_secrets.txt'로 복사한 뒤 값을 채우세요.
# (rauto_secrets.txt 가 있으면 서버가 자동으로 읽습니다. env 가 있으면 env 우선.)
# ★주의: rauto_secrets.txt 는 비밀번호 파일 → git 에 올리지 마세요(아웃바운드 금지).
#
# [Gmail] 일반 비번 아님 — Google 계정 '앱 비밀번호'(2단계인증 켠 뒤 발급, 16자리)
RAUTO_GMAIL_USER=hjoonygo@gmail.com
RAUTO_GMAIL_APP_PW=
#
# [Telegram] @BotFather 로 봇 생성 → 토큰. chat_id 는 @userinfobot 으로 확인.
