if barstate.islast
    cLong = color.rgb(59,130,246)
    cShort = color.rgb(255,61,139)
    cLoss = color.rgb(239,83,80)
    tp = color.new(color.black, 100)
    lo = math.min(pos, array.size(et) - 1)
    hi = math.min(pos + win - 1, array.size(et) - 1)
    if hi >= lo
        for i = lo to hi
            e = array.get(et,i)
            x = array.get(xt,i)
            a = array.get(aep,i)
            xx = array.get(xp,i)
            s = array.get(sd,i)
            p = array.get(pn,i)
            q = array.get(qt,i)
            col = s == 1 ? cLong : cShort
            fs = array.get(fst,i)
            for j = fs to fs + array.get(fcn,i) - 1
                label.new(array.get(ft,j), array.get(fpx,j), "✕", xloc=xloc.bar_time, style=label.style_label_center, color=tp, textcolor=color.white, size=size.tiny)
            line.new(e, a, x, a, xloc=xloc.bar_time, color=col, width=1)
            line.new(x, a, x, xx, xloc=xloc.bar_time, color=color.white, width=1, style=line.style_dashed)
            sl = s == 1 ? "L" : "S"
            label.new(e, a, sl + str.tostring(a, "#.0") + "@" + str.tostring(q, "#.000"), xloc=xloc.bar_time, style=label.style_label_up, color=tp, textcolor=col, size=size.small)
            label.new(x, xx, "✕", xloc=xloc.bar_time, style=label.style_label_center, color=tp, textcolor=color.white, size=size.tiny)
            pcol = p < 0 ? cLoss : cLong
            label.new(x, xx, (p > 0 ? "+" : "") + str.tostring(p, "#.##") + "%", xloc=xloc.bar_time, style=label.style_label_down, color=tp, textcolor=pcol, size=size.small)
